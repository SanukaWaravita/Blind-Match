@model LoginViewModel
@{
    ViewData["Title"] = "Login";
}

<div class="auth-split">
    <div class="auth-aside">
        <span class="eyebrow text-white">Secure Access</span>
        <h2>Sign in to your project approval workspace</h2>
        <p>Students, supervisors, and module leaders use the same secure platform with role-specific dashboards and access rules.</p>
        <ul class="mt-4">
            <li>Identity-aware but blind-review-first workflow</li>
            <li>Proposal tracking, matching, and oversight</li>
            <li>Academic administration UI tuned for coursework and demos</li>
        </ul>
    </div>
    <div class="auth-card">
        <span class="eyebrow">Secure Sign In</span>
        <h1>Welcome back</h1>
        <form asp-action="Login" method="post" novalidate>
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
            <div class="mb-3">
                <label asp-for="Email" class="form-label"></label>
                <input asp-for="Email" class="form-control" />
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Password" class="form-label"></label>
                <input asp-for="Password" class="form-control" />
                <span asp-validation-for="Password" class="text-danger small"></span>
            </div>
            <div class="form-check mb-3">
                <input asp-for="RememberMe" class="form-check-input" />
                <label asp-for="RememberMe" class="form-check-label"></label>
            </div>
            <button class="btn btn-accent w-100 py-3">Login</button>
        </form>
        <p class="mt-4 mb-0 text-muted">Need an account? <a asp-action="Register">Register here</a>.</p>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
