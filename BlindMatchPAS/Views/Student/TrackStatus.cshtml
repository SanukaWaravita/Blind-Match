@model IEnumerable<ProjectProposal>
@{
    ViewData["Title"] = "Track Status";
}

<div class="page-header-card">
    <span class="eyebrow">Status Tracking</span>
    <h1>Proposal pipeline</h1>
    <p class="text-muted mb-0">Follow each submission from pending review to final allocation.</p>
</div>

<div class="row g-4 mt-1">
@foreach (var proposal in Model)
{
    <div class="col-lg-6">
        <div class="panel-card h-100">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <h3 class="h5">@proposal.Title</h3>
                    <p class="text-muted">@proposal.ResearchArea.Name</p>
                </div>
                <span class="badge @BlindMatchPAS.Helpers.StatusBadgeHelper.GetBadgeClass(proposal.Status)">@proposal.Status</span>
            </div>
            <p class="small text-muted">Submitted @proposal.CreatedAt.ToLocalTime().ToString("dd MMM yyyy")</p>
            <a asp-action="ProposalDetails" asp-route-id="@proposal.Id" class="btn btn-outline-dark btn-sm">Open Details</a>
        </div>
    </div>
}
</div>
