@model ProjectProposal
@{
    ViewData["Title"] = "Matched Supervisor";
    var activeMatch = ViewBag.ActiveMatch as MatchRecord;
}

<div class="page-header-card">
    <span class="eyebrow">Final Allocation</span>
    <h1>Matched supervisor details</h1>
    <p class="text-muted mb-0">Identity is revealed only after a confirmed match has been finalized.</p>
</div>

@if (activeMatch is not null)
{
    <div class="row g-4 mt-1">
        <div class="col-lg-6">
            <div class="panel-card">
                <h3>Proposal</h3>
                <p><strong>Title:</strong> @Model.Title</p>
                <p><strong>Research Area:</strong> @Model.ResearchArea.Name</p>
                <p><strong>Status:</strong> @Model.Status</p>
            </div>
        </div>
        <div class="col-lg-6">
            <div class="panel-card">
                <h3>Supervisor</h3>
                <p><strong>Name:</strong> @activeMatch.SupervisorProfile.User.FullName</p>
                <p><strong>Email:</strong> @activeMatch.SupervisorProfile.User.Email</p>
                <p><strong>Department:</strong> @activeMatch.SupervisorProfile.Department</p>
                <p><strong>Expertise/Bio:</strong> @(activeMatch.SupervisorProfile.Bio ?? "No additional bio.")</p>
            </div>
        </div>
    </div>
}
