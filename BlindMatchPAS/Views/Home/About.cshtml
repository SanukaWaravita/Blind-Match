@{
    ViewData["Title"] = "About";
}

<div class="split-hero">
    <div class="page-header-card">
        <span class="eyebrow">About the System</span>
        <h1>Blind-Match PAS workflow</h1>
        <p class="mb-0">A coursework-ready approval platform built to support anonymous project proposal review, accountable final allocation, and cleaner university module coordination.</p>
    </div>
    <div class="panel-card">
        <div class="section-heading">
            <span class="eyebrow">Core Principles</span>
            <h2 class="h4">Academic-first design</h2>
        </div>
        <div class="detail-grid">
            <div class="detail-item"><span>Privacy</span><strong>Anonymous early-stage review</strong></div>
            <div class="detail-item"><span>Security</span><strong>Identity + role-based access control</strong></div>
            <div class="detail-item"><span>Consistency</span><strong>Strong proposal state transitions</strong></div>
            <div class="detail-item"><span>Control</span><strong>Admin reassignment and reports</strong></div>
        </div>
    </div>
</div>

<div class="row g-4 mt-2">
    <div class="col-lg-4">
        <div class="info-card h-100">
            <span class="eyebrow">Step 1</span>
            <h4>Proposal submission</h4>
            <p>Students register, complete their profile, and submit a proposal with title, abstract, tech stack, and research area.</p>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="info-card h-100">
            <span class="eyebrow">Step 2</span>
            <h4>Blind review</h4>
            <p>Supervisors browse only anonymous proposal content during the initial interest stage. No student identity is shown.</p>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="info-card h-100">
            <span class="eyebrow">Step 3</span>
            <h4>Confirmation and reveal</h4>
            <p>Once a supervisor confirms a match, the system reveals the student to the supervisor and the supervisor to the student.</p>
        </div>
    </div>
</div>
