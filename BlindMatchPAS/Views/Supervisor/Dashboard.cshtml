@model SupervisorDashboardViewModel
@{
    ViewData["Title"] = "Supervisor Dashboard";
}

<div class="split-hero">
    <div class="page-header-card">
        <span class="eyebrow">Supervisor Workspace</span>
        <h1>@Model.SupervisorName</h1>
        <p class="mb-0">Browse anonymous submissions aligned with your expertise and manage confirmed allocations with clarity.</p>
    </div>
    <div class="panel-card">
        <div class="section-heading">
            <span class="eyebrow">Blind Review</span>
            <h2 class="h4">Review guardrails</h2>
            <p>The platform protects student identity until your interest becomes a confirmed match.</p>
        </div>
        <div class="detail-grid">
            <div class="detail-item"><span>Visible</span><strong>Title, abstract, stack, research area</strong></div>
            <div class="detail-item"><span>Hidden</span><strong>Student identity until match confirmation</strong></div>
        </div>
    </div>
</div>

<div class="row g-4 mt-1">
    <div class="col-md-4"><div class="metric-card"><span>Anonymous Proposals</span><strong>@Model.AnonymousProposalCount</strong></div></div>
    <div class="col-md-4"><div class="metric-card"><span>Active Interests</span><strong>@Model.ActiveInterestCount</strong></div></div>
    <div class="col-md-4"><div class="metric-card"><span>Confirmed Matches</span><strong>@Model.MatchCount</strong></div></div>
</div>

<div class="row g-4 mt-4">
@foreach (var proposal in Model.AnonymousProposals)
{
    <div class="col-lg-4">
        <div class="panel-card proposal-card h-100">
            <div class="anonymous-ribbon">Identity Hidden</div>
            <h3 class="h5">@proposal.Title</h3>
            <p class="small text-muted">@proposal.ResearchArea</p>
            <p>@proposal.Abstract.Substring(0, Math.Min(proposal.Abstract.Length, 160))...</p>
            <a asp-action="ProposalDetails" asp-route-id="@proposal.Id" class="btn btn-outline-dark btn-sm">Review</a>
        </div>
    </div>
}
</div>
