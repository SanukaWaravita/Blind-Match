@model ProjectProposal
@{
    ViewData["Title"] = "Confirm Match";
}

<div class="page-header-card">
    <span class="eyebrow">Final Confirmation</span>
    <h1>Confirm supervisor match</h1>
    <p class="text-muted mb-0">Confirming this action reveals student identity and locks the proposal from student edits.</p>
</div>

<div class="row g-4 mt-1">
    <div class="col-lg-8">
        <div class="panel-card">
            <h3>@Model.Title</h3>
            <p><strong>Research Area:</strong> @Model.ResearchArea.Name</p>
            <p><strong>Technical Stack:</strong> @Model.TechnicalStack</p>
            <p>@Model.Abstract</p>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="panel-card">
            <form asp-action="ConfirmMatch" asp-route-id="@Model.Id" method="post">
                @Html.AntiForgeryToken()
                <div class="mb-3">
                    <label class="form-label">Notes (optional)</label>
                    <textarea name="notes" class="form-control" rows="5"></textarea>
                </div>
                <button class="btn btn-accent w-100 confirm-action" data-confirm-message="Confirm this match and reveal student identity?">Confirm Match</button>
            </form>
        </div>
    </div>
</div>
