@model ErrorViewModel
@{
    ViewData["Title"] = "Error";
}

<div class="empty-state text-center">
    <i class="bi bi-bug display-3 text-danger"></i>
    <h1 class="mt-3">Something went wrong</h1>
    <p class="text-muted">The request could not be completed. Please try again or contact the module leader.</p>
    @if (Model.ShowRequestId)
    {
        <p class="small text-muted">Request ID: @Model.RequestId</p>
    }
</div>
